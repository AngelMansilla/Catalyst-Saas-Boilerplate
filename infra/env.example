# PostgreSQL Configuration
POSTGRES_USER=catalyst
POSTGRES_PASSWORD=catalyst_dev_password
POSTGRES_DB=catalyst_db
POSTGRES_PORT=5432

# Redis Configuration
REDIS_PASSWORD=catalyst_redis_password
REDIS_PORT=6379
REDIS_MAX_MEMORY=256mb

# Kafka Configuration
KAFKA_PORT=9094
KAFKA_UI_PORT=8080

# LocalStack Configuration
LOCALSTACK_PORT=4566
LOCALSTACK_DEBUG=0

# Mailpit Settings
MAILPIT_DASHBOARD_PORT=8025
MAILPIT_SMTP_PORT=1025
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Application Configuration
APP_ENV=development


